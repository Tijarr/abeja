generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Domain {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  color       String  @default("#8b9ab0")
  sortOrder   Int     @default(0)
  description String?
  spaces      Space[]
}

model Space {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String
  color       String?    @default("#8b9ab0")
  sortOrder   Int?       @default(0)
  domainId    Int
  description String?
  contacts    Contact[]
  documents   Document[]
  domain      Domain     @relation(fields: [domainId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks       Task[]

  @@unique([domainId, slug])
}

model Task {
  id          Int            @id @default(autoincrement())
  spaceId     Int
  title       String?
  body        String
  tags        String[]
  status      String?
  deadline    DateTime?
  source      String?
  capRef      String?        @unique
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  completedAt DateTime?
  type        String         @default("normal")
  assignee    String?
  comments    Comment[]
  space       Space          @relation(fields: [spaceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents   TaskDocument[]
}

model TaskType {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  instructions String?
  tools        Json?
  structure    Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
}

model Comment {
  id         Int      @id @default(autoincrement())
  taskId     Int
  body       String
  author     String
  authorType String   @default("human")
  metadata   Json?
  createdAt  DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id])
}

model Document {
  id          Int            @id @default(autoincrement())
  spaceId     Int
  name        String
  url         String?
  storagePath String?
  mimeType    String?
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  space       Space          @relation(fields: [spaceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks       TaskDocument[]
}

model TaskDocument {
  taskId     Int
  documentId Int
  document   Document @relation(fields: [documentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task       Task     @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([taskId, documentId])
}

model Contact {
  id        Int       @id @default(autoincrement())
  spaceId   Int
  name      String
  role      String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime? @default(now())
  space     Space     @relation(fields: [spaceId], references: [id])
}

model SlugRedirect {
  id        Int      @id @default(autoincrement())
  oldSlug   String
  newSlug   String
  type      String
  createdAt DateTime @default(now())

  @@index([oldSlug, type])
}
